# Шаблон окружения. Скопируйте в backend/.env и заполните своими значениями.
# Сгенерировать ключ: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=замените-на-длинный-случайный-ключ
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=asu_platform
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Через запятую, без слэша в конце
CORS_ORIGINS=http://localhost:4200
